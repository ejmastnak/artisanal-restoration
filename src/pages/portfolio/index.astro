---
import client from "@tina/__generated__/client";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Portfolio from "@tina/pages/Portfolio/Index.tsx";
import { optimizeTinaImages } from '@/lib/optimizeTinaImages';

const content = await client.queries.myPortfolioPage({ relativePath: "index.json" });
const head = content.data.portfolioPage.head;

if (content.data.portfolioPage.featuredProjects) {
  const imagesToOptimize = content.data.portfolioPage.featuredProjects.map((project, idx) => {
    return {
      srcPath: ['data', 'portfolioPage', 'featuredProjects', `${idx}`, 'project', 'featuredImage'],
      altPath: ['data', 'portfolioPage', 'featuredProjects', `${idx}`, 'project', 'featuredImageAlt'],
      width: 800,
      idx: idx,
    }
  });
  await optimizeTinaImages(content, imagesToOptimize);
}

---

<BaseLayout head={head}>
  <Portfolio {...content} client:tina />
</BaseLayout>
